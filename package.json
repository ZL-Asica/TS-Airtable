{
  "name": "ts-airtable",
  "type": "module",
  "version": "0.4.2-beta.0",
  "packageManager": "pnpm@11.5.0",
  "description": "A tiny, fetch-based JavaScript/TypeScript Airtable Web and Node API client.",
  "author": {
    "name": "ZL Asica",
    "email": "zl@zla.app",
    "url": "https://github.com/ZL-Asica/"
  },
  "license": "MIT",
  "funding": "https://github.com/sponsors/ZL-Asica",
  "homepage": "https://airtable.zla.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZL-Asica/TS-Airtable.git"
  },
  "bugs": {
    "url": "https://github.com/ZL-Asica/TS-Airtable/issues"
  },
  "keywords": [
    "airtable",
    "airtable api",
    "airtable client",
    "airtable js",
    "airtable typescript",
    "airtable sdk",
    "airtable web api",
    "library",
    "utilities",
    "ZL Asica",
    "zl-asica"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.cts",
  "files": [
    "CHANGELOG.md",
    "LICENSE",
    "README.md",
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest",
    "test:ci": "vitest run",
    "test:package": "node scripts/verify-package-contract.ts",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build",
    "docs": "typedoc && pnpm docs:clean",
    "docs:clean": "node fix-markdown.ts && rm -rf docs/.vitepress/dist docs/.vitepress/cache",
    "docs:dev": "vitepress dev docs",
    "docs:publish:ci": "pnpm run docs && rm -rf docs/api.index.md && pnpm run docs:build",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@types/node": "^24.12.4",
    "@vitest/coverage-v8": "^4.1.7",
    "bumpp": "^11.1.0",
    "eslint": "^10.4.1",
    "eslint-plugin-format": "^2.0.1",
    "eslint-plugin-vuejs-accessibility": "^2.5.0",
    "husky": "^9.1.7",
    "nano-staged": "^1.0.2",
    "tsdown": "^0.22.1",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^6.0.3",
    "vitepress": "2.0.0-alpha.12",
    "vitepress-sidebar": "^1.36.1",
    "vitest": "^4.1.7",
    "vue": "^3.5.35"
  },
  "nano-staged": {
    "**/*.{ts,tsx,mjs,js,json,css,md,yml}": [
      "eslint --fix"
    ]
  }
}
